# ============================================================================
# ZYRIX CRM — Environment Variables Template
# ============================================================================
# Copy this file to `.env.local` and fill in the values:
#
#     cp .env.local.example .env.local
#
# NEVER commit `.env.local` to Git. Only this template belongs in Git.
# ============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# APP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Public app URLs — visible in browser
NEXT_PUBLIC_APP_URL=https://crm.zyrix.co
NEXT_PUBLIC_API_URL=https://api.crm.zyrix.co

# For local development, override with:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000

# App metadata (safe to expose)
NEXT_PUBLIC_APP_NAME=Zyrix CRM
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_ENV=development
# Options: development | staging | production


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — Google OAuth
# ─────────────────────────────────────────────────────────────────────────────
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# Authorized redirect URIs to add in Google Console:
#   https://crm.zyrix.co/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
#
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here


# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Google Analytics 4 — get from: https://analytics.google.com
# Leave empty to disable analytics in development
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Plausible Analytics (privacy-friendly alternative)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=crm.zyrix.co


# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
# Toggle features on/off without code changes
NEXT_PUBLIC_ENABLE_VOICE_AI=false
NEXT_PUBLIC_ENABLE_AI_CFO=true
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false


# ─────────────────────────────────────────────────────────────────────────────
# THIRD-PARTY INTEGRATIONS (Future — placeholders for now)
# ─────────────────────────────────────────────────────────────────────────────

# Zyrix Pay API (for subscription billing)
# NEXT_PUBLIC_ZYRIX_PAY_URL=https://api.pay.zyrix.co
# ZYRIX_PAY_API_KEY=your-pay-api-key-here

# Zyrix FinSuite API (for unified invoicing)
# NEXT_PUBLIC_ZYRIX_FINSUITE_URL=https://api.finsuite.zyrix.co
# ZYRIX_FINSUITE_API_KEY=your-finsuite-api-key-here

# Sentry error tracking (production only)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=zyrix
# SENTRY_PROJECT=zyrix-crm-frontend


# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT FLAGS
# ─────────────────────────────────────────────────────────────────────────────
# Turn on verbose logging in dev
# Set to "true" only during debugging
NEXT_PUBLIC_DEBUG=false

# Disable certain checks during local development
# (e.g. SSL cert validation, rate limits)
# NEVER set these to true in production
SKIP_SSL_VERIFY=false
DISABLE_RATE_LIMITS=false


# ─────────────────────────────────────────────────────────────────────────────
# NOTES FOR DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────
# Netlify:
#   Add these in: Site Settings → Environment variables
#   https://app.netlify.com/sites/YOUR_SITE/settings/env
#
# Cloudflare Pages:
#   Add in: Workers & Pages → Your project → Settings → Environment variables
#
# Railway (for backend, not this frontend repo):
#   Add in: Service → Variables
#
# Local development:
#   Copy this file to `.env.local` and fill in real values
#   Restart `npm run dev` after any changes
# ============================================================================